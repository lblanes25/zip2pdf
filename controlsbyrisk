"""
Controls-per-Risk Analysis
─────────────────────────
Reads an Excel file of audit controls, each tagged to one or more risks,
and produces:
  1. Average number of controls per risk, grouped by Risk Rating
  2. Same breakdown split by Control Type (Preventive / Detective)
  3. By Engagement: avg controls per risk within each engagement, with type split
  4. Preventive-to-Detective ratio by Risk Rating
  5. Detective-Only Risks: risks with zero preventive controls (flagged by rating)
  6. Control type distribution by Engagement vs. org-wide baseline
  7. A detail table: control count per individual risk

Usage:
  1. Update INPUT_FILE and column name constants below to match your file.
  2. Run:  python controls_by_risk.py
"""

import pandas as pd
from pathlib import Path

# ── CONFIG ───────────────────────────────────────────────────────────────
INPUT_FILE = "controls_data.xlsx"       # path to your Excel file
SHEET_NAME = 0                          # sheet index or name

# Column names — adjust these to match your file exactly
COL_CONTROL_ID   = "Control ID"
COL_CONTROL_TYPE = "Control Type"       # Preventive / Detective
COL_RISK_IDS     = "Risk ID(s)"         # may contain multiple, separated by comma/semicolon
COL_RISK_RATING  = "Risk Rating"
COL_ENGAGEMENT   = "Engagement ID"

# Risk rating display order
RATING_ORDER = ["Low", "Medium", "High", "Critical"]

# Delimiter(s) used when a control maps to multiple risks
RISK_DELIMITERS = r"[;,|]"             # splits on ; or , or |
# ─────────────────────────────────────────────────────────────────────────


def load_and_explode(filepath: str) -> pd.DataFrame:
    """Load the Excel file and explode multi-risk rows into one row per
    control–risk pair."""
    df = pd.read_excel(filepath, sheet_name=SHEET_NAME)

    # Standardize column names (strip whitespace)
    df.columns = df.columns.str.strip()

    # Split the Risk ID(s) column and explode
    df[COL_RISK_IDS] = (
        df[COL_RISK_IDS]
        .astype(str)
        .str.split(RISK_DELIMITERS)
    )
    df = df.explode(COL_RISK_IDS)
    df[COL_RISK_IDS] = df[COL_RISK_IDS].str.strip()

    # Normalize risk rating for consistent grouping
    df[COL_RISK_RATING] = df[COL_RISK_RATING].str.strip().str.title()

    # Normalize control type
    df[COL_CONTROL_TYPE] = df[COL_CONTROL_TYPE].str.strip().str.title()

    return df


def avg_controls_per_risk_by_rating(df: pd.DataFrame) -> pd.DataFrame:
    """For each risk, count distinct controls, then average those counts
    by risk rating."""
    controls_per_risk = (
        df.groupby([COL_RISK_IDS, COL_RISK_RATING])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Control_Count")
    )

    summary = (
        controls_per_risk
        .groupby(COL_RISK_RATING)["Control_Count"]
        .agg(["mean", "median", "min", "max", "count"])
        .rename(columns={
            "mean":   "Avg Controls per Risk",
            "median": "Median",
            "min":    "Min",
            "max":    "Max",
            "count":  "Number of Risks",
        })
        .reindex(RATING_ORDER)
        .dropna(how="all")
    )

    return summary


def avg_controls_by_rating_and_type(df: pd.DataFrame) -> pd.DataFrame:
    """Same as above but further split by Preventive / Detective."""
    controls_per_risk = (
        df.groupby([COL_RISK_IDS, COL_RISK_RATING, COL_CONTROL_TYPE])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Control_Count")
    )

    summary = (
        controls_per_risk
        .groupby([COL_RISK_RATING, COL_CONTROL_TYPE])["Control_Count"]
        .agg(["mean", "median", "min", "max", "count"])
        .rename(columns={
            "mean":   "Avg Controls per Risk",
            "median": "Median",
            "min":    "Min",
            "max":    "Max",
            "count":  "Number of Risks",
        })
    )

    # Reorder by rating
    summary = summary.reindex(RATING_ORDER, level=COL_RISK_RATING)

    return summary


def detail_table(df: pd.DataFrame) -> pd.DataFrame:
    """Full detail: control count per risk, with type breakdown."""
    detail = (
        df.groupby([COL_ENGAGEMENT, COL_RISK_IDS, COL_RISK_RATING])
        .agg(
            Total_Controls   = (COL_CONTROL_ID, "nunique"),
            Preventive_Count = (COL_CONTROL_TYPE, lambda x: (x == "Preventive").sum()),
            Detective_Count  = (COL_CONTROL_TYPE, lambda x: (x == "Detective").sum()),
        )
        .reset_index()
        .sort_values([COL_ENGAGEMENT, COL_RISK_RATING, COL_RISK_IDS],
                     key=lambda col: col.map({r: i for i, r in enumerate(RATING_ORDER)})
                     if col.name == COL_RISK_RATING else col)
    )

    return detail


def by_engagement(df: pd.DataFrame) -> pd.DataFrame:
    """Per engagement: avg controls per risk, split by rating and type.
    Useful for spotting engagements that over- or under-control relative
    to peers at the same risk rating."""
    # Count controls per risk within each engagement
    controls_per_risk = (
        df.groupby([COL_ENGAGEMENT, COL_RISK_IDS, COL_RISK_RATING])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Control_Count")
    )

    # Also count by type
    type_counts = (
        df.groupby([COL_ENGAGEMENT, COL_RISK_IDS, COL_RISK_RATING, COL_CONTROL_TYPE])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Count")
    )
    type_pivot = (
        type_counts
        .pivot_table(index=[COL_ENGAGEMENT, COL_RISK_IDS, COL_RISK_RATING],
                     columns=COL_CONTROL_TYPE, values="Count", fill_value=0)
        .reset_index()
    )

    # Merge total and type counts
    merged = controls_per_risk.merge(type_pivot, on=[COL_ENGAGEMENT, COL_RISK_IDS, COL_RISK_RATING])

    # Aggregate: average per engagement + rating
    agg_cols = {"Control_Count": ["mean", "count"]}
    for t in ["Preventive", "Detective"]:
        if t in merged.columns:
            agg_cols[t] = "mean"

    summary = (
        merged
        .groupby([COL_ENGAGEMENT, COL_RISK_RATING])
        .agg(**{
            "Avg Controls per Risk":   ("Control_Count", "mean"),
            "Number of Risks":         ("Control_Count", "count"),
            **({f"Avg Preventive": ("Preventive", "mean")} if "Preventive" in merged.columns else {}),
            **({f"Avg Detective":  ("Detective", "mean")}  if "Detective"  in merged.columns else {}),
        })
        .reset_index()
        .sort_values([COL_ENGAGEMENT, COL_RISK_RATING],
                     key=lambda col: col.map({r: i for i, r in enumerate(RATING_ORDER)})
                     if col.name == COL_RISK_RATING else col)
    )

    return summary


def preventive_detective_ratio(df: pd.DataFrame) -> pd.DataFrame:
    """Preventive-to-Detective ratio by Risk Rating.
    A ratio > 1 means more preventive than detective controls.
    Higher-rated risks should ideally skew preventive."""
    type_counts = (
        df.groupby([COL_RISK_RATING, COL_CONTROL_TYPE])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Control_Count")
    )

    pivot = (
        type_counts
        .pivot_table(index=COL_RISK_RATING, columns=COL_CONTROL_TYPE,
                     values="Control_Count", fill_value=0)
        .reindex(RATING_ORDER)
        .dropna(how="all")
    )

    # Ensure both columns exist
    for col in ["Preventive", "Detective"]:
        if col not in pivot.columns:
            pivot[col] = 0

    pivot["Total"] = pivot["Preventive"] + pivot["Detective"]
    pivot["Preventive %"] = (pivot["Preventive"] / pivot["Total"] * 100).round(1)
    pivot["Detective %"] = (pivot["Detective"] / pivot["Total"] * 100).round(1)
    pivot["P:D Ratio"] = pivot.apply(
        lambda r: f"{r['Preventive'] / r['Detective']:.2f}" if r["Detective"] > 0 else "N/A (no detective)",
        axis=1
    )

    return pivot


def detective_only_risks(df: pd.DataFrame) -> pd.DataFrame:
    """Flag risks that have ZERO preventive controls.
    Sorted by rating so High/Critical surface first."""
    risk_types = (
        df.groupby([COL_RISK_IDS, COL_RISK_RATING, COL_ENGAGEMENT, COL_CONTROL_TYPE])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Count")
    )

    pivot = (
        risk_types
        .pivot_table(index=[COL_RISK_IDS, COL_RISK_RATING, COL_ENGAGEMENT],
                     columns=COL_CONTROL_TYPE, values="Count", fill_value=0)
        .reset_index()
    )

    # Ensure Preventive column exists
    if "Preventive" not in pivot.columns:
        pivot["Preventive"] = 0
    if "Detective" not in pivot.columns:
        pivot["Detective"] = 0

    # Filter to only detective (zero preventive)
    detective_only = pivot[pivot["Preventive"] == 0].copy()

    # Add a severity flag
    severity_map = {"Critical": "URGENT", "High": "HIGH", "Medium": "REVIEW", "Low": "INFO"}
    detective_only["Flag"] = detective_only[COL_RISK_RATING].map(severity_map).fillna("")

    detective_only = detective_only.sort_values(
        [COL_RISK_RATING, COL_ENGAGEMENT, COL_RISK_IDS],
        key=lambda col: col.map({r: i for i, r in enumerate(RATING_ORDER)})
        if col.name == COL_RISK_RATING else col
    )

    return detective_only


def type_distribution_by_engagement(df: pd.DataFrame) -> pd.DataFrame:
    """Per engagement + rating: preventive %, detective %, and the
    org-wide baseline for comparison. Highlights engagements that
    deviate significantly from the norm."""
    # Org-wide baseline
    org_counts = (
        df.groupby([COL_RISK_RATING, COL_CONTROL_TYPE])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Count")
    )
    org_pivot = org_counts.pivot_table(
        index=COL_RISK_RATING, columns=COL_CONTROL_TYPE,
        values="Count", fill_value=0
    )
    for col in ["Preventive", "Detective"]:
        if col not in org_pivot.columns:
            org_pivot[col] = 0
    org_pivot["Org Preventive %"] = (
        org_pivot["Preventive"] / (org_pivot["Preventive"] + org_pivot["Detective"]) * 100
    ).round(1)
    org_baseline = org_pivot["Org Preventive %"].to_dict()

    # Per-engagement counts
    eng_counts = (
        df.groupby([COL_ENGAGEMENT, COL_RISK_RATING, COL_CONTROL_TYPE])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Count")
    )
    eng_pivot = (
        eng_counts
        .pivot_table(index=[COL_ENGAGEMENT, COL_RISK_RATING],
                     columns=COL_CONTROL_TYPE, values="Count", fill_value=0)
        .reset_index()
    )

    for col in ["Preventive", "Detective"]:
        if col not in eng_pivot.columns:
            eng_pivot[col] = 0

    eng_pivot["Total"] = eng_pivot["Preventive"] + eng_pivot["Detective"]
    eng_pivot["Preventive %"] = (eng_pivot["Preventive"] / eng_pivot["Total"] * 100).round(1)
    eng_pivot["Org Baseline Preventive %"] = eng_pivot[COL_RISK_RATING].map(org_baseline)
    eng_pivot["Deviation (pp)"] = (eng_pivot["Preventive %"] - eng_pivot["Org Baseline Preventive %"]).round(1)

    eng_pivot = eng_pivot.sort_values(
        [COL_RISK_RATING, "Deviation (pp)"],
        key=lambda col: col.map({r: i for i, r in enumerate(RATING_ORDER)})
        if col.name == COL_RISK_RATING else col,
        ascending=[True, True]
    )

    return eng_pivot


def single_control_risks(df: pd.DataFrame) -> pd.DataFrame:
    """Per risk rating: what % of risks have only one control mapped?
    High percentages at Critical/High ratings signal thin coverage."""
    controls_per_risk = (
        df.groupby([COL_RISK_IDS, COL_RISK_RATING])[COL_CONTROL_ID]
        .nunique()
        .reset_index(name="Control_Count")
    )

    total_by_rating = (
        controls_per_risk
        .groupby(COL_RISK_RATING)[COL_RISK_IDS]
        .count()
        .rename("Total Risks")
    )

    single_by_rating = (
        controls_per_risk[controls_per_risk["Control_Count"] == 1]
        .groupby(COL_RISK_RATING)[COL_RISK_IDS]
        .count()
        .rename("Single-Control Risks")
    )

    summary = pd.concat([total_by_rating, single_by_rating], axis=1).fillna(0)
    summary["Single-Control Risks"] = summary["Single-Control Risks"].astype(int)
    summary["% Single-Control"] = (summary["Single-Control Risks"] / summary["Total Risks"] * 100).round(1)
    summary = summary.reindex(RATING_ORDER).dropna(how="all")

    return summary


def main():
    filepath = Path(INPUT_FILE)
    if not filepath.exists():
        print(f"File not found: {filepath.resolve()}")
        print("Update INPUT_FILE in the script and re-run.")
        return

    df = load_and_explode(str(filepath))
    print(f"Loaded {len(df)} control–risk pairs "
          f"({df[COL_CONTROL_ID].nunique()} unique controls, "
          f"{df[COL_RISK_IDS].nunique()} unique risks, "
          f"{df[COL_ENGAGEMENT].nunique()} engagements)\n")

    # ── Report 1: Average controls per risk by rating ──
    print("=" * 60)
    print("AVG CONTROLS PER RISK — BY RISK RATING")
    print("=" * 60)
    print(avg_controls_per_risk_by_rating(df).to_string(float_format="%.1f"))

    # ── Report 2: Split by Preventive / Detective ──
    print("\n" + "=" * 60)
    print("AVG CONTROLS PER RISK — BY RATING & CONTROL TYPE")
    print("=" * 60)
    print(avg_controls_by_rating_and_type(df).to_string(float_format="%.1f"))

    # ── Report 3: By Engagement ──
    print("\n" + "=" * 60)
    print("AVG CONTROLS PER RISK — BY ENGAGEMENT & RATING")
    print("=" * 60)
    eng = by_engagement(df)
    print(eng.to_string(index=False, float_format="%.1f"))

    # ── Report 4: Preventive-to-Detective Ratio ──
    print("\n" + "=" * 60)
    print("PREVENTIVE-TO-DETECTIVE RATIO BY RISK RATING")
    print("=" * 60)
    ratio = preventive_detective_ratio(df)
    print(ratio.to_string())

    # ── Report 5: Detective-Only Risks ──
    print("\n" + "=" * 60)
    print("DETECTIVE-ONLY RISKS (ZERO PREVENTIVE CONTROLS)")
    print("=" * 60)
    det_only = detective_only_risks(df)
    if len(det_only) == 0:
        print("None found — all risks have at least one preventive control.")
    else:
        print(f"Found {len(det_only)} risks with no preventive controls:")
        print(det_only.to_string(index=False))

    # ── Report 6: Type Distribution by Engagement ──
    print("\n" + "=" * 60)
    print("CONTROL TYPE DISTRIBUTION BY ENGAGEMENT vs ORG BASELINE")
    print("=" * 60)
    dist = type_distribution_by_engagement(df)
    print(dist.to_string(index=False, float_format="%.1f"))

    # ── Report 7: Single-Control Risks ──
    print("\n" + "=" * 60)
    print("% OF RISKS WITH ONLY 1 CONTROL — BY RISK RATING")
    print("=" * 60)
    single = single_control_risks(df)
    print(single.to_string())

    # ── Report 8: Detail per risk ──
    print("\n" + "=" * 60)
    print("DETAIL: CONTROL COUNT PER RISK")
    print("=" * 60)
    detail = detail_table(df)
    print(detail.to_string(index=False))

    # ── Export to Excel ──
    output_file = "controls_by_risk_analysis.xlsx"
    with pd.ExcelWriter(output_file, engine="openpyxl") as writer:
        avg_controls_per_risk_by_rating(df).to_excel(writer, sheet_name="By Rating")
        avg_controls_by_rating_and_type(df).to_excel(writer, sheet_name="By Rating & Type")
        by_engagement(df).to_excel(writer, sheet_name="By Engagement", index=False)
        preventive_detective_ratio(df).to_excel(writer, sheet_name="P-D Ratio")
        detective_only_risks(df).to_excel(writer, sheet_name="Detective-Only Risks", index=False)
        type_distribution_by_engagement(df).to_excel(writer, sheet_name="Type Dist by Engagement", index=False)
        single_control_risks(df).to_excel(writer, sheet_name="Single-Control Risks")
        detail_table(df).to_excel(writer, sheet_name="Detail", index=False)

    print(f"\nResults exported to: {output_file}")


if __name__ == "__main__":
    main()
